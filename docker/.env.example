# Docker Environment Variables
# Copy this file to .env before running docker-compose

# PostgreSQL
POSTGRES_DB=aegis_intelligence
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=aegis_secure_pass

# External API Keys (Get from providers)
WEATHER_API_KEY=your_openweathermap_api_key_here
WAQI_API_KEY=your_waqi_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here
